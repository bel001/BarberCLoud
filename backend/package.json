{
  "name": "barbercloud-backend",
  "version": "2.0.0",
  "description": "Backend local y handlers serverless para BarberCloud",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "create-table": "node scripts/create-table.js",
    "create-demo-users": "node scripts/create-demo-users.js",
    "seed": "node scripts/seed.js",
    "dev": "node src/local-server.js",
    "start": "node src/local-server.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "node scripts/check-syntax.js"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.614.0",
    "@aws-sdk/client-dynamodb": "^3.614.0",
    "@aws-sdk/client-ses": "^3.614.0",
    "@aws-sdk/client-sns": "^3.614.0",
    "@aws-sdk/client-sqs": "^3.614.0",
    "@aws-sdk/lib-dynamodb": "^3.614.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "vitest": "^4.1.9"
  }
}
